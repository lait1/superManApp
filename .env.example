# ──────────────────────────────────────────────────────────────
# superMen — пример переменных окружения
# Скопируй в .env и заполни своими значениями:  cp .env.example .env
# Описание переменных: docs/07-architecture.md §5.
# ──────────────────────────────────────────────────────────────

# Строка подключения PostgreSQL.
# Для docker compose host = "postgres" (имя сервиса), для локального psql = "localhost".
# Можно оставить пустым при ENV=dev — тогда бэкенд поднимется на memory-store без БД
# (см. docs/13-running.md → «Офлайн-запуск»).
DATABASE_URL=postgres://supermen:supermen@localhost:5432/supermen?sslmode=disable

# Токен Telegram-бота из BotFather (/newbot). Только на сервере, в клиент НЕ попадает.
# Используется для валидации initData (HMAC-SHA256) и отправки нотификаций.
# См. docs/10-telegram-mini-app.md §2, §3.
TELEGRAM_BOT_TOKEN=

# Публичный HTTPS-URL Mini App (привязывается в BotFather, используется в web_app-кнопках).
# Telegram Mini App требует HTTPS и публичный домен. В dev может быть пустым.
TELEGRAM_WEBAPP_URL=https://app.supermen.example

# Порт REST API.
PORT=8080

# Окружение: dev | prod.
# dev — включает device-id fallback (запуск Mini App в обычном браузере без Telegram)
# и memory-store при пустом DATABASE_URL. См. docs/10-telegram-mini-app.md §7.
ENV=dev

# Интервал тика cron-шедулера нотификаций (Go duration: 30s, 5m, 10m ...).
# См. docs/06-notifications.md и docs/07-architecture.md §3c.
NOTIFY_TICK=5m
